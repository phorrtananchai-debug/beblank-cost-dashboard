# Future Firebase client configuration for Vite.
# These values are safe to expose only if they are standard Firebase web config values.
# Keep service account keys and admin credentials out of Vite env files.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
